.post footer {
  &::before {
    content: "";
    width: 100%;
    height: .0625rem;
    background: var(--grey-3);
    display: block;
    margin: 1.25rem auto 0rem;
  }

}

// 增大文章卡片内链接的触摸目标（Lighthouse target-size，inline 垂直 padding 不改布局但扩大命中区）
.item h3 a,
.item .meta.footer a {
  padding: .375rem .125rem;
}
